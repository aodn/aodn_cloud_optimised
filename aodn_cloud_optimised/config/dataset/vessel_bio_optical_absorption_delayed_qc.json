    "Citation": "IMOS [year-of-data-download], [Title], [data-access-URL], accessed [date-of-access]"
  },
  "run_settings": {
    "paths": [
      {
        "s3_uri": "s3://imos-data/IMOS/SRS/OC/BODBAW",
        "filter": [
          ".*absorption.*\\.nc$"
        ],
        "year_range": []
      }
    ],
    "cluster": {
      "mode": "coiled",
      "restart_every_path": true
    },
    "clear_existing_data": true,
    "raise_error": false,
    "force_previous_parquet_deletion": true,
    "batch_size": 50,
    "coiled_cluster_options": {
      "n_workers": [
        1,
        20
      ],
      "scheduler_vm_types": "m7i-flex.large",
      "worker_vm_types": "m7i-flex.xlarge",
      "allow_ingress_from": "me",
      "compute_purchase_option": "spot_with_fallback",
      "worker_options": {
        "nthreads": 4,
        "memory_limit": "8GB"
      }
    }
  }
