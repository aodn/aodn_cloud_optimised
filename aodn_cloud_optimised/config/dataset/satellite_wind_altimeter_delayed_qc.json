        "name": "TIME",
        "chunk": 20,
        "rechunk": false,
        "append_dim": true
      },
      "latitude": {
        "name": "LATITUDE",
        "chunk": 2000,
        "size": 0
      },
      "longitude": {
        "name": "LONGITUDE",
        "chunk": 2000,
        "size": 0
      }
    },
