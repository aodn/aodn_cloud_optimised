{
  "dataset_name": "satellite_wind_altimeter_delayed_qc",
  "logger_name": "satellite_wind_altimeter_delayed_qc",
  "cloud_optimised_format": "zarr",
  "run_settings": {
    "paths": [
      {
        "type": "files",
        "s3_uri": "s3://imos-data/IMOS/SRS/Surface-Waves/SAR_Wind/DELAYED/GRIDDED/SENTINEL-1/",
        "filter": [
          ".*\\.nc$"
        ],
        "year_range": [
          2017,
          2025
        ]
      }
    ],
    "cluster": {
      "mode": "coiled",
      "restart_every_path": true
    },
    "clear_existing_data": true,
    "raise_error": false,
    "coiled_cluster_options": {
      "n_workers": [
        1,
        50
      ],
      "scheduler_vm_types": "m7i-flex.large",
      "worker_vm_types": "m7i-flex.2xlarge",
      "allow_ingress_from": "me",
      "compute_purchase_option": "spot_with_fallback",
      "worker_options": {
        "nthreads": 1,
        "memory_limit": "32GB"
      }
    },
    "batch_size": 50
  },
  "metadata_uuid": "b02b929f-2caf-45d4-ac60-d4632b7ca0ca",
  "schema_transformation": {
    "dimensions": {
